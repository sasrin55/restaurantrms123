# Copy this file to .env and fill in the values before running locally.
# Never commit .env — it is listed in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. On Replit this is provisioned automatically.
# Locally: create a Postgres DB and paste the connection URL here.
DATABASE_URL=postgresql://user:password@localhost:5432/seated_rms

# ── Staff dashboard auth ──────────────────────────────────────────────────────
# API key required for all /v1/ external API routes (X-Api-Key header).
# Also used by the dashboard login form.
PUBLIC_API_KEY=your_api_key_here

# ── Session ───────────────────────────────────────────────────────────────────
# Secret used to sign express-session cookies. Any long random string.
SESSION_SECRET=change_me_to_a_long_random_string

# ── WhatsApp notifications ────────────────────────────────────────────────────
# Base URL of the WhatsApp sending service (e.g. https://your-wa-service.example.com)
WA_SERVICE_URL=https://your-whatsapp-service-url

# API key for the WhatsApp service (X-API-Key header sent to WA_SERVICE_URL)
WA_API_KEY=your_wa_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000 if not set.
PORT=5000
